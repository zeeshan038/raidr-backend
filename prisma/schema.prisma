generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//User
model User {
  id           String  @id @default(uuid())
  name         String
  email        String? @unique
  password     String?
  isVerified   Boolean @default(false)
  authProvider String  @default("email") // "email", "google", "apple"
  firebaseUid  String? @unique
  photoUrl     String  @default("")

  // OTP Fields (flattened from nested object)
  otpCode           String?
  otpCreatedAt      DateTime?
  otpUpdatedAt      DateTime?
  otpCodeExpireTime DateTime?

  avatarFrontUrl        String    @default("")
  avatarBackUrl    String    @default("")
  avatarUpdatedAt  DateTime?
  selectedAvatarId String    @default("")
  isNewUser        Boolean    @default(false)

  level                  Int     @default(1)
  xp_earned              Int     @default(0)
  xp_progress            Int     @default(0)
  green_boxes_count      Int     @default(0)
  golden_boxes_count     Int     @default(0)
  purple_boxes_count     Int     @default(0)
  distance_covered_km    Float   @default(0)
  has_seen_level_welcome Boolean @default(false)

  fcmTokens String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips         Trip[]
  adImpressions AdImpression[]
  adClaims      MerchantAdClaim[]
}

model Trip {
  id              String     @id @default(uuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id])
  routeTitle      String?
  destination     String?
  hotelLocation   String?
  hotelLat        Float?
  hotelLng        Float?
  destinationLat  Float?
  destinationLng  Float?
  tripDates       DateTime[]
  status          String? // "in-progress", "upcoming", "completed"
  tripPace        Boolean? // false=relaxed, true=intense
  radiusKm        Float?
  travelWith      String? // "Solo", "Couple", "Friends", "Family"
  interestedVibes String[]
  
  // JSON field for dynamic "yyyy-MM-dd" keys
  routesByDate Json?
  
  isShared    Boolean @default(false)
  inviteToken String?

  // Live navigation
  currentLatitude       Float?
  currentLongitude      Float?
  lastLocationUpdatedAt DateTime?
  navStatus             String? // "idle", "navigating", "paused"

  // Flow metadata
  flowKind          String? // "skip", "planYourTrip"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([isShared])
  @@index([userId, lastLocationUpdatedAt(sort: Desc)])
}

model Avatar {
  id            String   @id @default(uuid())
  avatarNumber  Int      @unique
  frontUrl      String
  backUrl       String
  requiredLevel Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//Merchant
model Merchant {
  id                 String        @id @default(uuid())
  email              String        @unique
  password           String?
  name               String
  businessName       String
  category           String
  defaultRadiusMeter Float
  phone              String?
  status             String        @default("pending")
  photoUrl           String
  merchantAds        MerchantAds[]
}

//Merchant Ads
model MerchantAds {
  id               String         @id @default(uuid())
  adCategory       String
  categoryName     String
  adTitle          String
  address          String
  approvalStatus   String         @default("pending")
  boxOpens         Int            @default(0)
  city             String
  country          String
  descriptionText  String
  imageUrl         String
  impressions      Int            @default(0)
  isActive         Boolean        @default(true)
  latitude         Float
  longitude        Float
  logoUrl          String
  merchantId       String
  merchant         Merchant       @relation(fields: [merchantId], references: [id])
  merchantName     String
  mysteryBoxReward String
  radius           Int            @default(0)
  rewardClaims     Int            @default(0)
  stockLimit       Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  adImpressions    AdImpression[]
  adClaims         MerchantAdClaim[]
  adCodes          MerchantAdCode[]
}

model AdImpression {
  id        String      @id @default(uuid())
  adId      String
  ad        MerchantAds @relation(fields: [adId], references: [id], onDelete: Cascade)
  userId    String? // Optional: If you want to track which user saw the ad
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())

  @@index([adId])
  @@index([userId])
  @@index([createdAt])
}

model MerchantAdClaim {
  id        String      @id @default(uuid())
  adId      String
  ad        MerchantAds @relation(fields: [adId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  code      MerchantAdCode?

  @@unique([userId, adId])
  @@index([adId])
  @@index([userId])
  @@index([createdAt])
}

model MerchantAdCode {
  id        String      @id @default(uuid())
  adId      String
  ad        MerchantAds @relation(fields: [adId], references: [id], onDelete: Cascade)
  code      String      @unique
  isClaimed Boolean     @default(false)
  claimId   String?     @unique
  claim     MerchantAdClaim? @relation(fields: [claimId], references: [id])
  createdAt DateTime    @default(now())

  @@index([adId])
  @@index([isClaimed])
}
