generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String             @id @default(uuid())
  name                   String
  email                  String?            @unique
  password               String?
  lat                    String?
  long                  String?
  isVerified             Boolean            @default(false)
  authProvider           String             @default("email")
  firebaseUid            String?            @unique
  photoUrl               String             @default("")
  otpCode                String?
  otpCreatedAt           DateTime?
  otpUpdatedAt           DateTime?
  otpCodeExpireTime      DateTime?
  avatarBackUrl          String             @default("")
  avatarUpdatedAt        DateTime?
  selectedAvatarId       String             @default("")
  level                  Int                @default(1)
  xp_earned              Int                @default(0)
  xp_progress            Int                @default(0)
  green_boxes_count      Int                @default(0)
  golden_boxes_count     Int                @default(0)
  purple_boxes_count     Int                @default(0)
  distance_covered_km    Float              @default(0)
  has_seen_level_welcome Boolean            @default(false)
  fcmToken               String?       
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  avatarFrontUrl         String             @default("")
  isNewUser              Boolean            @default(false)
  adImpressions          AdImpression[]
  boxCollectionLogs      BoxCollectionLog[]
  adClaims               MerchantAdClaim[]
  trips                  Trip[]
  raidrCoins             Int                @default(0)
  ownedAvatars           UserOwnedAvatar[]
  coinPurchases          RaidPurchaseHistory[]
  eventParticipations    LiveEventParticipant[]
  eventClaims            LiveEventClaim[]
}

model BoxCollectionLog {
  id                String   @id @default(uuid())
  userId            String
  boxType           String
  xpEarned          Int
  distanceCoveredKm Float    @default(0)
  source            String?
  lat               Float?
  lng               Float?
  createdAt         DateTime @default(now())
  adData            Json?
  isClaimed         Boolean  @default(false)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Trip {
  id                    String     @id @default(uuid())
  userId                String
  routeTitle            String?
  destination           String?
  hotelLocation         String?
  tripDates             DateTime[]
  status                String?
  tripPace              Boolean?
  radiusKm              Float?
  travelWith            String?
  interestedVibes       String[]
  routesByDate          Json?
  isShared              Boolean    @default(false)
  inviteToken           String?
  currentLatitude       Float?
  currentLongitude      Float?
  lastLocationUpdatedAt DateTime?
  navStatus             String?
  flowKind              String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  destinationLat        Float?
  destinationLng        Float?
  hotelLat              Float?
  hotelLng              Float?
  heading               Float?
  user                  User       @relation(fields: [userId], references: [id])

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([isShared])
  @@index([userId, lastLocationUpdatedAt(sort: Desc)])
}

model Avatar {
  id            String   @id @default(uuid())
  avatarNumber  Int      @unique
  frontUrl      String
  backUrl       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model Box {
  id            String   @id @default(uuid())
  boxNumber     Int      @unique
  frontUrl      String
  backUrl       String
  requiredLevel Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model RaidPurchaseHistory {
  id            String   @id @default(uuid())
  userId        String
  coinsAmount   Int     
  priceUsd      Float    
  transactionId String?  @unique 
  status        String   @default("completed") 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Merchant {
  id                 String        @id @default(uuid())
  email              String        @unique
  password           String?
  name               String
  businessName       String
  category           String
  defaultRadiusMeter Float?
  phone              String?
  status             String        @default("pending")
  photoUrl           String
  address            String                   @default("")
  credits            Int                      @default(0)
  merchantAds        MerchantAds[]
  liveEvents         LiveEvent[]
  creditPurchases    MerchantCreditPurchase[]
  creditLogs         MerchantCreditLog[]
}

model MerchantAds {
  id               String            @id @default(uuid())
  adCategory       String
  adTitle          String
  address          String
  approvalStatus   String            @default("pending")
  boxOpens         Int               @default(0)
  city             String
  country          String
  descriptionText  String
  imageUrl         String
  impressions      Int               @default(0)
  isActive         Boolean           @default(true)
  latitude         Float
  longitude        Float
  logoUrl          String
  merchantId       String
  merchantName     String
  mysteryBoxReward String
  radius           Int               @default(0)
  rewardClaims     Int               @default(0)
  stockLimit       Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  categoryName     String
  adImpressions    AdImpression[]
  adClaims         MerchantAdClaim[]
  adCodes          MerchantAdCode[]
  merchant         Merchant          @relation(fields: [merchantId], references: [id])
}

model AdImpression {
  id        String      @id @default(uuid())
  adId      String
  userId    String?
  createdAt DateTime    @default(now())
  ad        MerchantAds @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User?       @relation(fields: [userId], references: [id])

  @@index([adId])
  @@index([userId])
  @@index([createdAt])
}

model MerchantAdClaim {
  id        String          @id @default(uuid())
  adId      String
  userId    String
  createdAt DateTime        @default(now())
  ad        MerchantAds     @relation(fields: [adId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      MerchantAdCode?

  @@unique([userId, adId])
  @@index([adId])
  @@index([userId])
  @@index([createdAt])
}

model MerchantAdCode {
  id        String           @id @default(uuid())
  adId      String
  code      String           @unique
  isClaimed Boolean          @default(false)
  claimId   String?          @unique
  createdAt DateTime         @default(now())
  ad        MerchantAds      @relation(fields: [adId], references: [id], onDelete: Cascade)
  claim     MerchantAdClaim? @relation(fields: [claimId], references: [id])

  @@index([adId])
  @@index([isClaimed])
}

model LiveEvent {
  id              String                 @id @default(uuid())
  title           String
  description     String
  merchantId      String
  commanderAvatar String                 @default("")
  imageUrl        String                 @default("")
  latitude        Float
  longitude       Float
  startTime       DateTime
  endTime         DateTime
  reward          String
  rewardQuantity  Int
  remainingQty    Int                    // Track remaining stock
  status          String                 @default("draft") // draft, pending_approval, scheduled, live, completed, cancelled
  size            String                 @default("small") // small, medium, large
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  merchant        Merchant               @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  participants    LiveEventParticipant[]
  claims          LiveEventClaim[]
  creditLogs      MerchantCreditLog[]

  @@index([merchantId])
  @@index([status])
  @@index([startTime])
  @@index([endTime]) 
}

model LiveEventParticipant {
  id        String    @id @default(uuid())
  eventId   String
  userId    String
  joinedAt  DateTime  @default(now())
  event     LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model LiveEventClaim {
  id        String    @id @default(uuid())
  eventId   String
  userId    String
  code      String?
  claimedAt DateTime  @default(now())
  xpEarned  Int
  lat       Float?
  lng       Float?
  event     LiveEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model UserOwnedAvatar {
  id          String   @id @default(uuid())
  userId      String
  storeId     String   
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}


model MerchantCreditPurchase {
  id            String   @id @default(uuid())
  merchantId    String
  creditsAmount Int
  priceUsd      Float
  transactionId String?  @unique
  status        String   @default("completed") // pending, completed, failed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([createdAt(sort: Desc)])
}

model MerchantCreditLog {
  id          String     @id @default(uuid())
  merchantId  String
  amount      Int        // e.g. +100 for purchase, -25 for medium event
  type        String     // purchase, event_creation, refund, admin_adjustment
  description String
  eventId     String?
  createdAt   DateTime   @default(now())

  merchant    Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  event       LiveEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([merchantId])
  @@index([createdAt(sort: Desc)])
}


// Admin 
model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
    id          String   @id @default(uuid())
    name        String
    frontUrl    String   
    backUrl     String    
    price       Int      @default(0)
    isNew       Boolean  @default(false)
    isFeatured  Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    owners      UserOwnedAvatar[]
}
