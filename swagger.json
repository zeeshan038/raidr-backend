{
  "openapi": "3.0.1",
  "info": {
    "title": "Raidr API",
    "description": "Backend API for Raidr including user authentication and profile management.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://188.245.72.1:5001/api",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:5001/api",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 6 }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "SendOtpRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" }
        }
      },
      "VerifyOtpRequest": {
        "type": "object",
        "required": ["email", "otp"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "otp": { "type": "string" }
        }
      },
      "GoogleSignInRequest": {
        "type": "object",
        "required": ["firebaseToken"],
        "properties": {
          "firebaseToken": { "type": "string" }
        }
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": ["email", "newPassword"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "newPassword": { "type": "string", "minLength": 6 }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "fcmToken": { "type": "string" },
          "location": { "type": "string" }
        }
      },
      "UpdatePhotoUrlRequest": {
        "type": "object",
        "properties": {
          "avatarFrontUrl": { "type": "string" },
          "avatarBackUrl": { "type": "string" }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean" },
          "msg": { "type": "string" }
        }
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "email": { "type": "string" },
          "name": { "type": "string" },
          "isVerified": { "type": "boolean" },
          "authProvider": { "type": "string", "enum": ["email", "google", "apple"] },
          "photoUrl": { "type": "string", "nullable": true },
          "avatarFrontUrl": { "type": "string", "nullable": true },
          "avatarBackUrl": { "type": "string", "nullable": true },
          "level": { "type": "integer" },
          "xp_earned": { "type": "number" },
          "xp_progress": { "type": "number" },
          "green_boxes_count": { "type": "integer" },
          "golden_boxes_count": { "type": "integer" },
          "purple_boxes_count": { "type": "integer" },
          "distance_covered_km": { "type": "number" }
        }
      },
      "AuthTokenResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean" },
          "msg": { "type": "string" },
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/UserDto" }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "status": { "type": "boolean", "example": false },
          "msg": { "type": "string", "example": "Something went wrong" }
        }
      },
      "TripDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "routeTitle": { "type": "string", "nullable": true },
          "destination": { "type": "string" },
          "hotelLocation": { "type": "string" },
          "hotelLat": { "type": "number", "nullable": true },
          "hotelLng": { "type": "number", "nullable": true },
          "destinationLat": { "type": "number", "nullable": true },
          "destinationLng": { "type": "number", "nullable": true },
          "tripDates": {
            "type": "array",
            "items": { "type": "string", "format": "date-time" }
          },
          "status": { "type": "string", "nullable": true },
          "tripPace": { "type": "boolean" },
          "radiusKm": { "type": "number" },
          "travelWith": { "type": "string" },
          "interestedVibes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "routesByDate": {
            "type": "object",
            "nullable": true,
            "properties": {
              "0": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/RouteStopDto" }
              },
              "1": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/RouteStopDto" }
              },
              "2": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/RouteStopDto" }
              }
            }
          },
          "isShared": { "type": "boolean" },
          "inviteToken": { "type": "string", "nullable": true },
          "currentLatitude": { "type": "number", "nullable": true },
          "currentLongitude": { "type": "number", "nullable": true },
          "lastLocationUpdatedAt": { "type": "string", "format": "date-time", "nullable": true },
          "navStatus": { "type": "string", "nullable": true, "enum": ["idle", "navigating", "paused"] },
          "flowKind": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "RouteStopDto": {
        "type": "object",
        "properties": {
          "index": { "type": "integer" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "visible": { "type": "boolean" },
          "isSurprise": { "type": "boolean" },
          "isAchieved": { "type": "boolean" }
        }
      },
      "GeneratedRoutesDto": {
        "type": "object",
        "properties": {
          "dayRoutes": {
            "type": "object",
            "properties": {
              "0": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/RouteStopDto" }
              },
              "1": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/RouteStopDto" }
              },
              "2": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/RouteStopDto" }
              }
            }
          },
          "refreshQueue": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RouteStopDto" }
          }
        }
      },
      "GeoPointDto": {
        "type": "object",
        "properties": {
          "lat": { "type": "number" },
          "lng": { "type": "number" }
        }
      },
      "PlacePoolItemDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "category": { "type": "string" },
          "rating": { "type": "number" },
          "photos": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          }
        }
      },
      "AvatarItemDto": {
        "type": "object",
        "properties": {
          "front": { "type": "string" },
          "back": { "type": "string" },
          "locked": { "type": "boolean", "description": "True if the avatar is locked (user level too low)" },
          "requiredLevel": { "type": "integer", "description": "User level required to unlock this avatar" }
        }
      },
      "MerchantAdDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "adCategory": { "type": "string" },
          "categoryName": { "type": "string" },
          "adTitle": { "type": "string" },
          "address": { "type": "string" },
          "approvalStatus": { "type": "string" },
          "boxOpens": { "type": "integer" },
          "city": { "type": "string" },
          "country": { "type": "string" },
          "descriptionText": { "type": "string" },
          "imageUrl": { "type": "string" },
          "impressions": { "type": "integer" },
          "isActive": { "type": "boolean" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "logoUrl": { "type": "string" },
          "merchantId": { "type": "string" },
          "merchantName": { "type": "string" },
          "mysteryBoxReward": { "type": "string" },
          "radius": { "type": "integer" },
          "rewardClaims": { "type": "integer" },
          "stockLimit": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CreateCampaignRequest": {
        "type": "object",
        "required": ["adTitle", "adCategory", "address", "latitude", "longitude", "mysteryBoxReward", "stockLimit", "adImage", "categoryName"],
        "properties": {
          "adTitle": { "type": "string" },
          "adCategory": { "type": "string" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "country": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "mysteryBoxReward": { "type": "string" },
          "stockLimit": { "type": "integer" },
          "adImage": { "type": "string" },
          "descriptionText": { "type": "string" },
          "categoryName": { "type": "string" },
          "logoUrl": { "type": "string" },
          "isActive": { "type": "boolean" },
          "radius": { "type": "integer" }
        }
      },
      "UpdateCampaignRequest": {
        "type": "object",
        "properties": {
          "adTitle": { "type": "string" },
          "adCategory": { "type": "string" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "country": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "mysteryBoxReward": { "type": "string" },
          "stockLimit": { "type": "integer" },
          "adImage": { "type": "string" },
          "descriptionText": { "type": "string" },
          "categoryName": { "type": "string" },
          "logoUrl": { "type": "string" },
          "isActive": { "type": "boolean" },
          "radius": { "type": "integer" }
        }
      }
    }
  },
  "paths": {
    "/user/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthTokenResponse" }
              }
            }
          },
          "400": { "description": "Validation Error or User exists", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthTokenResponse" } } } },
          "400": { "description": "Invalid credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/send-otp": {
      "post": {
        "tags": ["Auth"],
        "summary": "Send OTP to user email",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendOtpRequest" } } }
        },
        "responses": {
          "200": { "description": "OTP sent", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "User not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/verify-otp": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify OTP",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VerifyOtpRequest" } } }
        },
        "responses": {
          "200": { "description": "OTP verified successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthTokenResponse" } } } },
          "400": { "description": "Invalid or expired OTP", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/signin-with-google": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign in with Google Firebase Token",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GoogleSignInRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated with Google",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/AuthTokenResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "user": {
                          "type": "object",
                          "properties": {
                            "isNewUser": { "type": "boolean" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Request a password reset OTP",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendOtpRequest" } } }
        },
        "responses": {
          "200": { "description": "Password reset OTP sent", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset password using OTP",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ResetPasswordRequest" } } }
        },
        "responses": {
          "200": { "description": "Password reset successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/update": {
      "put": {
        "tags": ["User Profile"],
        "summary": "Update user details",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateUserRequest" } } }
        },
        "responses": {
          "200": { "description": "User updated successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthTokenResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/whoami": {
      "get": {
        "tags": ["User Profile"],
        "summary": "Get current user profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User profile fetched successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthTokenResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/update-photo-url": {
      "patch": {
        "tags": ["User Profile"],
        "summary": "Update User Avatar/Background URLs",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdatePhotoUrlRequest" } } }
        },
        "responses": {
          "200": { "description": "Avatar updated successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthTokenResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/avatars": {
      "get": {
        "tags": ["User Profile"],
        "summary": "Get all avatars and their lock status based on user level",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Avatars fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean" },
                    "msg": { "type": "string" },
                    "currentLevel": { "type": "integer" },
                    "avatars": {
                      "type": "object",
                      "additionalProperties": { "$ref": "#/components/schemas/AvatarItemDto" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/delete": {
      "delete": {
        "tags": ["User Profile"],
        "summary": "Delete user account",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User deleted successfully", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/user/get-all-keys": {
      "get": {
        "tags": ["User Profile"],
        "summary": "Get all environment keys for maps and AI",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Keys fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean" },
                    "msg": { "type": "string" },
                    "keys": {
                      "type": "object",
                      "properties": {
                        "googleApiKey": { "type": "string" },
                        "openWeatherApiKey": { "type": "string" },
                        "openRouterApiKey": { "type": "string" },
                        "openAiApiKey": { "type": "string" },
                        "mapboxToken": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } },
          "500": { "description": "Internal server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } } } }
        }
      }
    },
    "/trip/weather": {
      "get": {
        "tags": ["Trip"],
        "summary": "Get city weather and pictures",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "query",
            "name": "lat",
            "schema": { "type": "number" },
            "required": true,
            "description": "Latitude of the city"
          },
          {
            "in": "query",
            "name": "lng",
            "schema": { "type": "number" },
            "required": true,
            "description": "Longitude of the city"
          }
        ],
        "responses": {
          "200": {
            "description": "Weather and images fetched successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "boolean" },
                    "msg": { "type": "string" },
                    "weather": {
                      "type": "object",
                      "description": "Detailed weather data from OpenWeather API",
                      "properties": {
                        "coord": {
                          "type": "object",
                          "properties": {
                            "lon": { "type": "number" },
                            "lat": { "type": "number" }
                          }
                        },
                        "weather": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": { "type": "integer" },
                              "main": { "type": "string" },
                              "description": { "type": "string" },
                              "icon": { "type": "string" }
                            }
                          }
                        },
                        "main": {
                          "type": "object",
                          "properties": {
                            "temp": { "type": "number" },
                            "feels_like": { "type": "number" },
                            "temp_min": { "type": "number" },
                            "temp_max": { "type": "number" },
                            "pressure": { "type": "integer" },
                            "humidity": { "type": "integer" }
                          }
                        },
                        "wind": {
                          "type": "object",
                          "properties": {
                            "speed": { "type": "number" },
                            "deg": { "type": "integer" },
