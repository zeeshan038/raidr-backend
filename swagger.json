{
  "openapi": "3.0.1",
  "info": {
    "title": "Raidr",
    "description": "Backend API for Raidr including user authentication and profile management.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://188.245.72.1:5001/api",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:5001/api",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/user/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 6 }
                },
                "required": ["name", "email", "password"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully" },
          "400": { "description": "Validation Error or User exists" }
        }
      }
    },
    "/user/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP sent successfully" },
          "400": { "description": "Invalid credentials" }
        }
      }
    },
    "/user/send-otp": {
      "post": {
        "tags": ["Auth"],
        "summary": "Send OTP to user email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP sent" },
          "400": { "description": "User not found" }
        }
      }
    },
    "/user/verify-otp": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verify OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "otp": { "type": "string" }
                },
                "required": ["email", "otp"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP verified successfully. Returns JWT token." },
          "400": { "description": "Invalid or expired OTP" }
        }
      }
    },
    "/user/signin-with-google": {
      "post": {
        "tags": ["Auth"],
        "summary": "Sign in with Google Firebase Token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "firebaseToken": { "type": "string" }
                },
                "required": ["firebaseToken"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successfully authenticated with Google" }
        }
      }
    },
    "/user/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Request a password reset OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset OTP sent" }
        }
      }
    },
    "/user/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset password using OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "newPassword": { "type": "string", "minLength": 6 }
                },
                "required": ["email", "newPassword"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset successfully" }
        }
      }
    },
    "/user/update": {
      "put": {
        "tags": ["User Profile"],
        "summary": "Update user details",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "fcmToken": { "type": "string" },
                  "location": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated successfully" }
        }
      }
    },
    "/user/whoami": {
      "get": {
        "tags": ["User Profile"],
        "summary": "Get current user profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User profile fetched successfully" }
        }
      }
    },
    "/user/update-photo-url": {
      "patch": {
        "tags": ["User Profile"],
        "summary": "Update User Avatar/Background URLs",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "avatarUrl": { "type": "string" },
                  "avatarBackUrl": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Avatar updated successfully" }
        }
      }
    },
    "/user/delete": {
      "delete": {
        "tags": ["User Profile"],
        "summary": "Delete user account",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User deleted successfully" }
        }
      }
    }
  }
}
